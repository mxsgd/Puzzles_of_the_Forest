  m_Script: {fileID: 11500000, guid: 3f4cdcf595a579f44ab1abbe6b7f84cb, type: 3}
  m_Name: BiomeDecorationTintProfile
  m_EditorClassIdentifier: Assembly-CSharp::BiomeDecorationTintProfile
  rules:
  - tag: Grass
    beigeColor: {r: 0.86, g: 0.81, b: 0.66, a: 1}
    greenColor: {r: 0.4, g: 0.62, b: 0.36, a: 1}
    tintStrength: 0.3
    noiseScale: 0.065
    noiseOffset: {x: 100, y: 200}
    addWave: 1
    waveScale: 0.12
    waveInfluence: 0.3
    forestBiasToGreen: 0.25
    meadowBiasToGreen: 0.45
    mountainousBiasToGreen: 0.05
    bushyBiasToGreen: 0.2
  - tag: Bush
    beigeColor: {r: 0.86, g: 0.81, b: 0.66, a: 1}
    greenColor: {r: 0.4, g: 0.62, b: 0.36, a: 1}
    tintStrength: 0.22
    noiseScale: 0.065
    noiseOffset: {x: 100, y: 200}
    addWave: 1
    waveScale: 0.12
    waveInfluence: 0.3
    forestBiasToGreen: 0.25
    meadowBiasToGreen: 0.35
    mountainousBiasToGreen: 0.05
    bushyBiasToGreen: 0.28
  fallbackRule:
    tag: Default
    beigeColor: {r: 0.86, g: 0.81, b: 0.66, a: 1}
    greenColor: {r: 0.4, g: 0.62, b: 0.36, a: 1}
